# ===== ENVIRONMENT VARIABLES =====
# Copy this to .env and fill in your actual values
# NEVER commit .env to git

# ===== CORE CONFIG =====
ENV=development
DEBUG=True
PROJECT_NAME=Nexus-Brain
PROJECT_VERSION=5.0.0

# ===== TELEGRAM BOT =====
TELEGRAM_BOT_TOKEN=8848528929:AAHDqFRK2qSnBC_jzjif5XgU_InGORPfWK4
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=your_secret_token_here

# ===== DATABASE =====
# Supabase PostgreSQL connection
DATABASE_URL=postgresql://user:password@localhost:5432/nexus_brain
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ===== REDIS =====
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_DB=1

# ===== LLM PROVIDERS =====
OPENAI_API_KEY=sk-your_openai_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key
COHERE_API_KEY=your_cohere_key
GROQ_API_KEY=your_groq_key

# ===== OPTIONAL: LOCAL OLLAMA =====
OLLAMA_API_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-large-en-v1.5

# ===== EXTERNAL SERVICES =====
TAVILY_API_KEY=your_tavily_key  # Web search fallback
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
SENTRY_DSN=https://your_sentry_dsn

# ===== SECURITY & ENCRYPTION =====
PII_MASTER_KEY=your_fernet_key_here  # Generate with: from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
JWT_SECRET_KEY=your_jwt_secret_key_for_local_testing
ENCRYPTION_KEY_VERSION=1

# ===== RATE LIMITING =====
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ===== OBSERVABILITY =====
LOG_LEVEL=INFO
PROMETHEUS_PORT=8001

# ===== FEATURE FLAGS =====
FEATURE_GRAPH_RAG=false
FEATURE_QUERY_EXPANSION=false
FEATURE_SEMANTIC_CACHE=true
FEATURE_ENTITY_EXTRACTION=false
FEATURE_VISION=true
FEATURE_VOICE=true

# ===== COST LIMITS =====
USER_DAILY_BUDGET_USD=5.0
COST_WARNING_THRESHOLD=0.8
COST_HARD_LIMIT_THRESHOLD=1.5

# ===== SECRETS MANAGER (Optional - for production) =====
# Use Doppler, Infisical, or Supabase Vault
SECRETS_MANAGER=local  # Options: local, doppler, infisical, supabase_vault

# ===== DEPLOYMENT =====
WORKERS=1
WORKER_CLASS=uvicorn.workers.UvicornWorker
